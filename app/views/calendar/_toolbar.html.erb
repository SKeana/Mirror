<div class="toolbar">
  <div class="toolbar__menu" data-controller="menu">
    <button type="button"
            class="toolbar__menu-btn"
            data-action="click->menu#toggle"
            aria-label="Open menu">
      <span class="toolbar__menu-icon" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
    <div class="toolbar__menu-panel" data-menu-target="panel" hidden>
      <%= link_to "Calendar",  root_path, class: "toolbar__menu-item" %>
      <%= link_to "New block", new_time_block_path, class: "toolbar__menu-item" %>
      <%= link_to "Template",  templates_path, class: "toolbar__menu-item" %>
    </div>
  </div>

  <%= link_to "‹", @prev_url,
              class: "toolbar__nav",
              aria: { label: "Previous #{@view}" } %>

  <span class="toolbar__week-date"><%= @label %></span>

  <%= link_to "Today", @today_url, class: "toolbar__today" %>

  <span class="toolbar__view-toggle">
    <%= link_to "Week",  root_path(date: @date.iso8601),
                class: "toolbar__view-btn #{'is-active' if @view == :week}" %>
    <%= link_to "Month", month_path(date: @date.iso8601),
                class: "toolbar__view-btn #{'is-active' if @view == :month}" %>
    <%= link_to "Year",  year_path(date: @date.iso8601),
                class: "toolbar__view-btn #{'is-active' if @view == :year}" %>
  </span>

  <button type="button"
          class="toolbar__dark-toggle"
          data-controller="dark-mode"
          data-action="click->dark-mode#toggle"
          aria-label="Toggle dark mode">
    <span aria-hidden="true">&#9728;&#65039;/&#127769;</span>
  </button>

  <%= link_to "›", @next_url,
              class: "toolbar__nav",
              aria: { label: "Next #{@view}" } %>
</div>
