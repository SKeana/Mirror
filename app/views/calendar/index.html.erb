<% days = %w[Sunday Monday Tuesday Wednesday Thursday Friday Saturday] %>
<% hours = (0..23).to_a %>

<div class="page">
  <%= render "toolbar" %>

  <div class="calendar">
    <div class="calendar__corner"></div>
    <% days.each_with_index do |day, i| %>
      <% date = @week_start + i %>
      <div class="calendar__day-header <%= 'is-today' if date == @today %>">
        <span class="calendar__day-name"><%= day %></span>
        <span class="calendar__day-date"><%= date.day %></span>
      </div>
    <% end %>

    <div class="calendar__times">
      <% hours.each do |h| %>
        <div class="calendar__time-label"><%= format("%02d:00", h) %></div>
      <% end %>
    </div>

    <% days.each_with_index do |day, i| %>
      <% date = @week_start + i %>
      <div class="calendar__day-column <%= 'is-today' if date == @today %>" data-day="<%= day %>" data-date="<%= date.iso8601 %>">
        <% hours.each do |h| %>
          <div class="calendar__hour-cell" data-hour="<%= h %>"></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
